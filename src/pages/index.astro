---
import Layout from "../layouts/Layout.astro"
import Navbar from "../components/Navbar.vue"
import Footer from "../components/Footer.vue"
import ProjectCard from "../components/ProjectCard.vue"
import ContactForm from "../components/ContactForm.vue"
import { getCollection } from "astro:content"

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order)
---

<Layout
  title="Kelvin N.O. Lamptey | CTO & Systems Engineer"
  description="I build scalable, high-impact systems for African tech ecosystems — from cloud platforms and hosting infrastructure to educational tools that democratize learning."
>
  <Navbar client:load />

  <main>
    <section id="home" class="mx-auto max-w-5xl px-6 pt-28 pb-20 sm:pt-36 sm:pb-28">
      <div class="flex flex-col items-center gap-10 sm:flex-row sm:items-start">
        <img
          src="/images/hero-typing.jpg"
          alt="Kelvin N.O. Lamptey"
          class="h-48 w-48 rounded-xs object-cover shadow-md sm:h-56 sm:w-56"
        />
        <div>
          <h1 class="text-2xl font-bold text-text-secondary sm:text-3xl">
            Kelvin N.O. Lamptey
          </h1>
          <p class="mt-3 text-md font-semibold text-text-inverse">
            Software Engineer, Yango STEM Fellow &amp; CTO @ KENOL Tech
          </p>
          <p class="mt-5 max-w-2xl text-sm leading-relaxed text-text-primary">
            I build scalable, high-impact systems for African tech ecosystems — from
            cloud platforms and hosting infrastructure to educational tools that
            democratize learning. My work bridges full-stack engineering, DevOps,
            and product strategy to ship production-grade solutions that solve real
            problems.
          </p>
        </div>
      </div>
    </section>

    <section id="projects" class="bg-black/[.02] py-20 sm:py-24">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="text-xl font-bold text-text-secondary">
          Featured Systems
        </h2>
        <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2">
          {projects.map((p) => (
            <ProjectCard
              title={p.data.title}
              description={p.data.description}
              techStack={p.data.techStack}
              image={p.data.image}
              githubUrl={p.data.githubUrl}
              liveUrl={p.data.liveUrl}
            />
          ))}
        </div>
      </div>
    </section>

    <section id="about" class="mx-auto max-w-5xl px-6 py-20 sm:py-24">
      <h2 class="text-xl font-bold text-text-secondary">About Me</h2>
      <p class="mt-5 max-w-3xl text-sm leading-relaxed text-text-primary">
        I am a Computer Science student at Ghana Communication Technology
        University (GCTU) and Co-founder of KENOL Tech, where I lead engineering
        across cloud infrastructure, web platforms, and open-source tooling. As a
        Yango STEM Fellow, I am deeply invested in leveraging technology to build
        resilient, scalable solutions that address Africa's unique infrastructure
        and education challenges. My work spans the full stack — from orchestrating
        Docker containers and managing PostgreSQL clusters to crafting intuitive
        Vue.js frontends.
      </p>
      <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-3">
        <img
          src="/images/yango-award.jpg"
          alt="Receiving award at Yango STEM Fellowship"
          class="h-56 w-full rounded-xs object-cover shadow-sm"
        />
        <img
          src="/images/formal-sitting.jpg"
          alt="Speaking at a gathering"
          class="h-56 w-full rounded-xs object-cover shadow-sm"
        />
        <img
          src="/images/formal-standing.jpg"
          alt="Formal professional portrait"
          class="h-56 w-full rounded-xs object-cover shadow-sm"
        />
      </div>
    </section>

    <section id="contact" class="bg-black/[.02] py-20 sm:py-24">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="text-xl font-bold text-text-secondary">Get In Touch</h2>
        <div class="mt-8 max-w-lg">
          <ContactForm client:idle />
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
